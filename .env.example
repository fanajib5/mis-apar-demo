APP_NAME="APAR Management Demo"
APP_ENV=production
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# Deployment mode: single|saas|hybrid|offline
APP_DEPLOYMENT_MODE=single

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# Database - SQLite (default untuk demo)
DB_CONNECTION=sqlite
DATABASE_URL=file:/app/database/database.sqlite

# Uncomment untuk MySQL/PostgreSQL:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=file

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@apar-demo.com"
MAIL_FROM_NAME="${APP_NAME}"

# Multi-Tenant
TENANT_ENABLED=true
TENANT_ID=1
TENANT_DOMAIN_PATTERN=%s.aparmanagement.com

# Sync (Hybrid mode)
SYNC_ENABLED=false
SYNC_ENDPOINT=https://api.aparmanagement.com/sync
SYNC_INTERVAL_SECONDS=30
SYNC_BATCH_SIZE=100

# License (White-label)
LICENSE_KEY=
LICENSE_VALIDATION_URL=https://license.aparmanagement.com/validate

# Offline mode
OFFLINE_STORAGE_PATH=/data/local
OFFLINE_DB_PATH=/data/database.sqlite

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
